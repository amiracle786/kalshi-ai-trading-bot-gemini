# ============================================================================
# KALSHI AI TRADING BOT - ENVIRONMENT CONFIGURATION (Claude-only)
# ============================================================================

# Kalshi API Configuration
# Get your API key from: https://trading.kalshi.com/settings/api (for production)
# Or: https://demo.kalshi.co (for demo trading)
KALSHI_API_KEY=your_kalshi_api_key_here

# Path to your RSA private key file (download from Kalshi API settings)
# Place the .pem file in the project root and set path to ./kalshi_private_key.pem
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Kalshi API Base URL
# For demo trading (paper): https://demo-api.kalshi.co/trade-api/v2
# For live trading: https://api.elections.kalshi.com/trade-api/v2
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# ============================================================================
# ANTHROPIC (Claude) API Configuration
# ============================================================================

# Get your API key from: https://console.anthropic.com/api/keys
# Add $5-10 in credits to get started
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (defaults to haiku for cost, but can upgrade)
# Options: claude-haiku-4-5-20251001 (cheapest), claude-sonnet-4-6, claude-opus-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================

# Set to 'true' for live trading with real money
# Set to 'false' for paper trading (simulated)
LIVE_TRADING_ENABLED=false

# Max daily AI API spending (in USD) - default $5.00
# This prevents runaway API costs
MAX_DAILY_AI_COST=5.00

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable file logging
ENABLE_FILE_LOGGING=true

# Enable console logging
ENABLE_CONSOLE_LOGGING=true

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database path (stores all trades, positions, analysis history)
DATABASE_URL=sqlite:///trading_system.db

# ============================================================================
# PERFORMANCE MONITORING
# ============================================================================

# Enable performance tracking and P&L calculations
ENABLE_PERFORMANCE_MONITORING=true

# How often to log performance metrics (in minutes)
PERFORMANCE_LOG_INTERVAL_MINUTES=15

# ============================================================================
# PYTHON COMPATIBILITY (for Python 3.14+)
# ============================================================================

# Uncomment if using Python 3.14 or later
# PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1
